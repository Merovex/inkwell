<%# locals: (comment:) %>
<%# One comment row — a .list__item (avatar | content | far-right action), %>
<%# except the content column is byline + rich text instead of a linked %>
<%# title. The frame id (comment_<record id>) doubles as the copy-link %>
<%# anchor and the inline-edit swap target. %>
<%= turbo_frame_tag "comment_#{comment.record_id}", class: "list__item comment" do %>
  <span class="avatar list__avatar" aria-hidden="true"><%= avatar_initials(comment.creator) %></span>

  <div class="comment__content">
    <p class="comment__byline u-text-muted">
      <span class="u-text-strong"><%= comment.creator.name.presence || comment.creator.email_address %></span>
      · <time datetime="<%= comment.record.created_at.iso8601 %>"><%= comment.record.created_at.strftime("%b %-d at %H:%M") %></time>
      <% if comment.event_updated? %>
        · Edited
      <% end %>
    </p>
    <div class="comment__body u-flow"><%= comment.content %></div>
  </div>

  <div class="list__action comment__actions">
    <button type="button" class="button button--icon button--ghost" popovertarget="comment-menu-<%= comment.record_id %>" aria-haspopup="menu" aria-label="Comment actions">
      <%= inline_svg_tag "lucide/ellipsis-vertical.svg", class: "lucide", size: "16px" %>
    </button>
    <div class="menu menu--context" popover id="comment-menu-<%= comment.record_id %>" role="menu" data-controller="anchored-popover" data-anchored-popover-placement-value="top">
      <button type="button" class="button button--icon button--ghost menu__close" popovertarget="comment-menu-<%= comment.record_id %>" popovertargetaction="hide" aria-label="Close menu">
        <%= inline_svg_tag "lucide/x.svg", class: "lucide", size: "20px" %>
      </button>
      <button type="button" class="menu__item" role="menuitem"
              data-controller="clipboard" data-action="clipboard#copy"
              data-clipboard-text-value="<%= post_url(comment.record.parent_id, anchor: "comment_#{comment.record_id}") %>"
              popovertarget="comment-menu-<%= comment.record_id %>" popovertargetaction="hide">Copy link</button>
      <%= link_to "Edit", edit_comment_path(comment.record), class: "menu__item", role: "menuitem" %>
      <hr class="menu__separator">
      <%# Break out of the comment frame: after a trash the comment is gone %>
      <%# from the page, so the response has no matching frame to extract. %>
      <%= button_to "Move to trash", comment_path(comment.record), method: :delete, class: "menu__item", role: "menuitem",
            form: { data: { turbo_confirm: "Move this comment to trash?", turbo_frame: "_top" } } %>
    </div>
  </div>
<% end %>
