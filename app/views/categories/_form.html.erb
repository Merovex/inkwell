<%# locals: (category:) %>
<%= render "shared/error_summary", model: category %>

<%= form_with model: category do |f| %>
  <div class="field">
    <%= f.label :icon, class: "field__label" %>
    <%= f.text_field :icon, class: "field__control", placeholder: "📢" %>
    <p class="field__hint u-text-muted">An emoji — it leads the byline on every message in this category.</p>
  </div>

  <div class="field">
    <%= f.label :name, class: "field__label" %>
    <%= f.text_field :name, class: "field__control", placeholder: "Announcement", required: true %>
  </div>

  <div class="u-cluster">
    <%= f.submit category.persisted? ? "Save changes" : "Add this category", class: "button button--primary" %>
    <%= link_to "Never mind", categories_path, class: "button" %>
  </div>
<% end %>
