<% content_for :title, "Unsubscribed — #{site_settings.site_name}" %>

<section class="press-article">
  <header class="press-article__head">
    <h1 class="press-article__title">You've been unsubscribed</h1>
    <p class="press-article__byline">You won't receive further emails from <%= site_settings.site_name %>. Changed your mind? You can always <%= link_to "subscribe again", newsletter_path, class: "press-link" %>.</p>
  </header>
</section>
