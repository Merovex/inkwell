<% content_for :title, "Unsubscribed — #{site_settings.site_name}" %>

<section class="press-shell">
  <header class="press-header u-flow u-flow-half">
    <h1 class="press-display-lg">You've been unsubscribed</h1>
    <p class="press-muted">You won't receive further emails from <%= site_settings.site_name %>. Changed your mind? You can always <%= link_to "subscribe again", newsletter_path, class: "press-link" %>.</p>
  </header>
</section>
