<% content_for :title, "Subscription confirmed — #{site_settings.site_name}" %>

<section class="press-shell">
  <header class="press-header u-flow u-flow-half">
    <% if @already_confirmed %>
      <h1 class="press-display-lg">You're already subscribed</h1>
      <p class="press-muted">This link was already used — you're all set for <%= site_settings.site_name %>.</p>
    <% else %>
      <h1 class="press-display-lg">You're subscribed</h1>
      <p class="press-muted">Thanks for confirming — you'll hear from <%= site_settings.site_name %> soon.</p>
    <% end %>
  </header>
  <div>
    <p><%= link_to "Back to home", root_path, class: "press-link" %></p>
  </div>
</section>
