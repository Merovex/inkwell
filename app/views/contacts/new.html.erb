<% content_for :title, "Contact — #{site_settings.site_name}" %>

<section class="press-article">
  <header class="press-article__head">
    <h1 class="press-article__title">Get in touch</h1>
    <p class="press-article__byline">
      Send a note to <%= site_settings.site_name %>. You'll get a one-time email to
      confirm your address — click it and your message reaches us.
    </p>
  </header>

  <% if flash[:notice] %>
    <p class="press-form__flash press-form__flash--notice"><%= flash[:notice] %></p>
  <% elsif flash[:alert] %>
    <p class="press-form__flash press-form__flash--alert"><%= flash[:alert] %></p>
  <% end %>

  <%= form_with model: @missive, url: contact_path, method: :post, class: "press-form" do |f| %>
    <%# Honeypot + time-to-submit trap; invisible to humans, catches bots. %>
    <%= invisible_captcha %>

    <%= f.label :name, "Your name", class: "press-form__label" %>
    <%= f.text_field :name, required: true, class: "press-form__input", autocomplete: "name" %>

    <%= f.label :email_address, "Email address", class: "press-form__label" %>
    <%= f.email_field :email_address, required: true, placeholder: "you@example.com",
          class: "press-form__input", autocomplete: "email" %>

    <%= f.label :subject, "Subject", class: "press-form__label" %>
    <%= f.text_field :subject, required: true, class: "press-form__input" %>

    <%= f.label :body, "Message", class: "press-form__label" %>
    <%= f.text_area :body, required: true, rows: 8, class: "press-form__input" %>

    <div class="press-form__row">
      <%= f.submit "Send message", class: "press-btn press-btn--primary" %>
    </div>
  <% end %>
</section>
