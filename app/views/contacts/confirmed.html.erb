<% content_for :title, "Message confirmed — #{site_settings.site_name}" %>

<section class="press-shell">
  <header class="press-header u-flow u-flow-half">
    <% if @already_confirmed %>
      <h1 class="press-display-lg">Already confirmed</h1>
      <p class="press-muted">
        This link was already used — your message reached <%= site_settings.site_name %>. We'll be in touch.
      </p>
    <% else %>
      <h1 class="press-display-lg">Message confirmed</h1>
      <p class="press-muted">
        Thanks — your message has reached <%= site_settings.site_name %>. We'll be in touch.
      </p>
    <% end %>
  </header>
  <div>
    <p><%= link_to "Back to home", root_path, class: "press-link" %></p>
  </div>
</section>
