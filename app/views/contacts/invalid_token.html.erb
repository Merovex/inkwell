<% content_for :title, "Link expired — #{site_settings.site_name}" %>

<section class="press-article">
  <header class="press-article__head">
    <h1 class="press-article__title">This link has expired</h1>
    <p class="press-article__byline">
      Confirmation links are valid for a few days. Please send your message again.
    </p>
  </header>
  <div class="press-article__body">
    <p><%= link_to "Back to the contact form", contact_path, class: "press-link" %></p>
  </div>
</section>
