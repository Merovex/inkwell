<!DOCTYPE html>
<html data-theme="<%= current_theme %>" data-tint="<%= current_tint %>">
  <head>
    <title><%= content_for(:title) || "Inkwell" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Inkwell">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# PWA manifest (routes enabled in config/routes.rb) — develop-as-PWA, ADR 0005. %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Lexxy editor + rendered rich-text content styles (gem asset, outside the :app bundle). %>
    <%# Linked BEFORE :app so lexxy-theme.css can override the gem's :root variables. %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= "hotwire-native" if hotwire_native? %>">
    <%= render "layouts/header" %>
    <main class="canvas"><%= yield %></main>
    <%= render "layouts/toasts" %>
  </body>
</html>
