<% content_for :title, "#{@post.title} — #{site_settings.site_name}" %>
<% content_for :meta_description, @post.summary(length: 200) %>
<% content_for :json_ld do %>
  <%= json_ld_tag({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": @post.title,
    "datePublished": @post.published_at.iso8601,
    "dateModified": @record.updated_at.iso8601,
    "author": { "@type": "Person", "name": @post.byline },
    "description": @post.summary(length: 200),
    "publisher": { "@type": "Organization", "name": site_settings.site_name }
  }) %>
<% end %>

<article class="press-shell">
  <a href="<%= blog_path %>" class="press-back">
    <%= inline_svg_tag "lucide/chevron-right.svg", class: "lucide press-back__icon", size: "16px" %>
    Back to the blog
  </a>

  <header class="press-header u-flow u-flow-half">
    <time class="press-meta" datetime="<%= @post.published_at.iso8601 %>">
      <%= @post.published_at.strftime("%B %-d, %Y") %>
    </time>
    <h1 class="press-display-lg"><%= @post.title %></h1>
    <p class="press-muted">by <%= byline_link(@post) %></p>
  </header>

  <div class="press-body prose">
    <%= @post.content %>
  </div>
</article>
