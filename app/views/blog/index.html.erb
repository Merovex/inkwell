<% content_for :title, "Blog — Merovex Press" %>

<div class="press-page">
  <header class="press-page__head">
    <h1 class="press-page__title">Writing on craft, history, and the worlds behind the books.</h1>
    <p class="press-page__intro">
      Notes from Ben Wilson and Troy Buzby — on the making of the stories, the
      history underneath them, and what genre fiction is for.
    </p>
  </header>

  <% if @posts.any? %>
    <div class="press-articles">
      <% @posts.each do |post| %>
        <% cache post do %>
          <article class="press-article-card">
            <time class="press-article-card__date" datetime="<%= post.published_at.iso8601 %>">
              <%= post.published_at.strftime("%B %-d, %Y") %>
            </time>
            <h2 class="press-article-card__title">
              <%= link_to post.title, blog_post_path(post.record.to_slug), class: "press-article-card__link" %>
            </h2>
            <p class="press-article-card__desc">
              <%= post.content.to_plain_text.to_s.truncate(300) %>
            </p>
            <span class="press-article-card__cta" aria-hidden="true">
              Read article <%= inline_svg_tag "lucide/chevron-right.svg", class: "lucide", size: "16px" %>
            </span>
          </article>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="press-articles__empty">No posts published yet — check back soon.</p>
  <% end %>
</div>
