<% content_for :title, "Subscribers — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Subscribers", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">Subscribers</h1>
  <div class="perma-header__content">
    <p class="u-text-muted">
      <%= @counts["confirmed"].to_i %> confirmed ·
      <%= @counts["pending"].to_i %> pending ·
      <%= @counts["unsubscribed"].to_i %> unsubscribed
    </p>
    <nav class="perma-header__toolbar" aria-label="Actions">
      <%= link_to admin_subscribers_path(format: :csv), class: "button button--small" do %>
        <%= inline_svg_tag "lucide/file-text.svg", class: "lucide", size: "16px" %> Export CSV
      <% end %>
    </nav>
  </div>
</header>

<% badges = { "confirmed" => "badge--success", "pending" => "badge--warning", "unsubscribed" => "badge--danger" } %>

<% if @subscribers.any? %>
  <ul class="list">
    <% @subscribers.each do |subscriber| %>
      <li class="list__item">
        <span class="list__body">
          <span class="list__titlerow">
            <span class="list__title"><%= subscriber.email_address %></span>
            <span class="badge <%= badges[subscriber.status] %>"><%= subscriber.status %></span>
          </span>
          <span class="list__meta">
            <span class="list__byline">
              <%= "via #{subscriber.source} · " if subscriber.source.present? %>joined <%= subscriber.created_at.strftime("%b %-d, %Y") %>
            </span>
          </span>
        </span>
        <% unless subscriber.unsubscribed? %>
          <%= button_to unsubscribe_admin_subscriber_path(subscriber), method: :patch, form_class: "list__action",
                class: "button button--icon button--ghost", title: "Unsubscribe",
                "aria-label": "Unsubscribe #{subscriber.email_address}",
                form: { data: { turbo_confirm: "Unsubscribe #{subscriber.email_address}?" } } do %>
            <%= inline_svg_tag "lucide/circle-x.svg", class: "lucide", size: "16px" %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty">
    <span class="empty__icon"><%= inline_svg_tag "lucide/inbox.svg", class: "lucide", size: "40px" %></span>
    <p class="empty__title">No subscribers yet</p>
    <p class="empty__text">When readers join the newsletter from the public site, they'll appear here.</p>
  </div>
<% end %>
