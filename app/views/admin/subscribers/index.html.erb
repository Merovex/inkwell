<% content_for :title, "Subscribers — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Subscribers", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">Subscribers</h1>
  <div class="perma-header__content">
    <%# One state at a time; each tab links to that state's view. %>
    <nav class="perma-header__toolbar" aria-label="Subscriber states">
      <% Admin::SubscribersController::STATES.each do |state| %>
        <%= link_to admin_subscribers_path(state: state),
              class: "button button--small#{' button--primary' if state == @state}",
              aria: { current: ("page" if state == @state) } do %>
          <%= state.capitalize %> <span class="u-text-muted">(<%= @counts[state].to_i %>)</span>
        <% end %>
      <% end %>
      <%= link_to admin_subscribers_path(state: @state, format: :csv), class: "button button--small" do %>
        <%= inline_svg_tag "lucide/file-text.svg", class: "lucide", size: "16px" %> Export
      <% end %>
    </nav>
  </div>
</header>

<% if @subscribers.any? %>
  <ul class="list">
    <% @subscribers.each do |subscriber| %>
      <li class="list__item">
        <span class="list__body">
          <span class="list__titlerow">
            <span class="list__title"><%= subscriber.email_address %></span>
            <% if subscriber.confirmed? && subscriber.re_engagement_sent_at %>
              <span class="badge badge--warning">Nudged</span>
            <% end %>
          </span>
          <span class="list__meta">
            <span class="list__byline">
              <%= "via #{subscriber.source} · " if subscriber.source.present? %>joined <%= subscriber.created_at.strftime("%b %-d, %Y") %><%= " · last opened #{subscriber.last_engaged_at.strftime('%b %-d, %Y')}" if subscriber.last_engaged_at %>
            </span>
          </span>
        </span>
        <% unless subscriber.unsubscribed? %>
          <%= button_to unsubscribe_admin_subscriber_path(subscriber), method: :patch, form_class: "list__action",
                class: "button button--icon button--ghost", title: "Unsubscribe",
                "aria-label": "Unsubscribe #{subscriber.email_address}",
                form: { data: { turbo_confirm: "Unsubscribe #{subscriber.email_address}?" } } do %>
            <%= inline_svg_tag "lucide/circle-x.svg", class: "lucide", size: "16px" %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty">
    <span class="empty__icon"><%= inline_svg_tag "lucide/inbox.svg", class: "lucide", size: "40px" %></span>
    <p class="empty__title">No <%= @state %> subscribers</p>
    <p class="empty__text">
      <% if @state == "confirmed" %>
        Confirmed subscribers — those who completed double opt-in — appear here.
      <% elsif @state == "pending" %>
        People who signed up but haven't confirmed their email yet appear here.
      <% else %>
        People who've unsubscribed (or were sunset for inactivity) appear here.
      <% end %>
    </p>
  </div>
<% end %>
