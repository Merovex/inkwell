<%# locals: (author:, url:) %>
<%= render "admin/shared/error_summary", model: author %>

<%= form_with model: author, url: url, multipart: true, class: "settings" do |f| %>
  <div class="field">
    <%= f.label :name, "Name", class: "field__label" %>
    <%= f.text_field :name, class: "field__control", required: true, placeholder: "Pen name" %>
  </div>

  <div class="field">
    <%= f.label :bio, "Bio", class: "field__label" %>
    <%= f.rich_textarea :bio, placeholder: "A short bio…", "aria-label": "Bio" %>
  </div>

  <div class="field">
    <label class="field__label"><%= f.check_box :default %> Default author — preselected when composing</label>
  </div>

  <%= f.submit "Save", class: "button button--primary" %>
<% end %>
