<% content_for :title, "Change Log: #{@book.title} — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Books", admin_books_path], [@book.title, admin_book_path(@record)], ["Change Log", nil]] do %>
  <%= link_to "Back to book", admin_book_path(@record), class: "menu__item", role: "menuitem" %>
<% end %>

<header class="perma-header">
  <h1 class="perma-header__title">Change Log</h1>
</header>

<ol class="history">
  <% @versions.each_with_index do |version, i| %>
    <% previous = i.positive? ? @versions[i - 1] : nil %>
    <li class="history__entry">
      <p class="history__stamp u-text-muted"><%= version_timestamp(version) %></p>
      <p class="history__line">
        <span class="u-text-strong"><%= version.creator.display_name %></span>
        <%= version_event_line(version, previous, noun: "book") %>
      </p>
      <% if version != @current && (version.body_id != @current.body_id || version.title != @current.title) %>
        <%= link_to "See the changes", admin_book_change_path(@record, version), class: "history__action" %>
      <% end %>
      <% if previous.nil? %>
        <%= link_to "View this version", admin_book_version_path(@record, version), class: "history__action" %>
      <% end %>
    </li>
  <% end %>
</ol>
