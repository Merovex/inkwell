<% content_for :title, "#{@book.title} — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Books", admin_books_path], [@book.title, nil]], menu: false do %>
  <%= render "composer_actions", book: @book %>
<% end %>

<%= render "form", book: @book, url: admin_book_path(@record) %>

<%= render "cover", book: @book, record: @record %>

<section class="book-series">
  <h2 class="book-series__title">Series</h2>
  <%= render "admin/installments/combobox",
        context: "book", url: search_admin_series_index_path,
        anchor_param: "book_record_id", selected_param: "series_record_id",
        anchor_id: @record.id, placeholder: "Search series to add…" %>
  <ul class="mrows" id="book_series">
    <% @book.installments.each do |installment| %>
      <% series = Series.current.find_by(record_id: installment.series_record_id) %>
      <% next unless series %>
      <%= render "admin/books/series_row", installment: installment, series: series %>
    <% end %>
  </ul>
</section>
