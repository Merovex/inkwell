<%# locals: (book:, record:) %>
<%# Cover preview + upload/replace/remove. %>
<section class="cover">
  <div class="cover__preview">
    <% if book.cover? %>
      <%= image_tag book.cover, class: "cover__image", alt: "#{book.title} cover" %>
    <% else %>
      <span class="cover__image cover__image--empty" aria-hidden="true">No cover</span>
    <% end %>
  </div>

  <div class="cover__actions">
    <%= form_with url: admin_book_depiction_path(record), method: :post, multipart: true, class: "cover__upload" do %>
      <%= file_field_tag :depiction, accept: "image/*", class: "field__control" %>
      <%= submit_tag(book.cover? ? "Replace cover" : "Upload cover", class: "button button--small") %>
    <% end %>
    <% if book.cover? %>
      <%= button_to "Remove cover", admin_book_depiction_path(record), method: :delete, class: "button button--small" %>
    <% end %>
  </div>
</section>
