<% content_for :title, "Version: #{@version.title} — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Books", admin_books_path], [@book.title, admin_book_path(@record)], ["Change Log", admin_book_events_path(@record)], ["Version", nil]] do %>
  <%= link_to "Change Log", admin_book_events_path(@record), class: "menu__item", role: "menuitem" %>
  <%= link_to "Back to book", admin_book_path(@record), class: "menu__item", role: "menuitem" %>
<% end %>

<header class="perma-header">
  <h1 class="perma-header__title"><%= @version.title %></h1>
  <p class="perma-header__content u-text-muted">
    Version from <%= version_timestamp(@version) %>
    by <span class="u-text-strong"><%= @version.creator.display_name %></span>
  </p>
</header>

<article class="u-flow">
  <%= @version.content %>
</article>
