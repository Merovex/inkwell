<%# locals: (book:) %>
<% if book.persisted? && book.published? %>
  <%= link_to "Never mind", admin_book_path(book.record), class: "button" %>
  <%= button_tag "Update", form: "composer", class: "button button--primary" %>
<% elsif book.persisted? && book.scheduled? %>
  <%= render "admin/shared/scheduler", form: "composer", schedulable: book,
        noun: "book", drafts_href: admin_books_path, drafts_label: "Books" %>
  <%= link_to "Never mind", admin_book_path(book.record), class: "button" %>
  <%= button_tag "Save", form: "composer", class: "button button--primary" %>
<% else %>
  <%= render "admin/shared/scheduler", form: "composer",
        noun: "book", drafts_href: admin_books_path, drafts_label: "Books" %>
  <%= button_tag "Save draft", form: "composer", class: "button" %>
  <%= button_tag "Publish", form: "composer", name: "publish", value: "1", class: "button button--primary" %>
<% end %>
