<% content_for :title, "#{@post.title} — Inkwell" %>
<% can_manage = allowed_to?(:manage, @record) %>

<%# The title is editable in place (creator/admin only): click it. Saving %>
<%# submits the enclosed form (PATCH posts#update) — on a published post %>
<%# that's a tracked rename. %>
<div data-controller="editable">
  <%= render "admin/shared/canvas_head", crumbs: [["Posts", admin_posts_path], [@post.title, nil]],
        edit_href: (edit_admin_post_path(@record) if can_manage) do %>
    <% if can_manage %>
      <% if @post.published? %>
        <% if @post.pinned_at %>
          <%= button_to "Unpin", admin_post_pin_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
        <% else %>
          <%= button_to "Pin", admin_post_pin_path(@record), class: "menu__item", role: "menuitem" %>
        <% end %>
        <%= button_to "Revert to draft", admin_post_publish_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
      <% else %>
        <%= button_to "Publish", admin_post_publish_path(@record), class: "menu__item", role: "menuitem" %>
      <% end %>
      <hr class="menu__separator">
    <% end %>
    <%= link_to "View History", admin_post_events_path(@record), class: "menu__item", role: "menuitem" %>
    <% if can_manage %>
      <hr class="menu__separator">
      <%= button_to "Move to trash", admin_post_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
    <% end %>
  <% end %>

  <header class="perma-header">
    <% if can_manage %>
      <h1 class="perma-header__title editable__display" data-editable-target="display"
          data-action="click->editable#edit" title="Click to rename" tabindex="0"><%= @post.title %></h1>
      <%= form_with model: @post, url: admin_post_path(@record) do |f| %>
        <%= f.text_field :title, hidden: true, class: "perma-header__title editable__input",
              aria: { label: "Title" },
              data: { editable_target: "input",
                      action: "blur->editable#save keydown.enter->editable#save keydown.esc->editable#cancel" } %>
      <% end %>
    <% else %>
      <h1 class="perma-header__title"><%= @post.title %></h1>
    <% end %>
    <p class="perma-header__content u-text-muted">
      <span class="u-text-strong"><%= @record.creator.display_name %></span>
      <% if @post.published? %>
        · <%= l @post.published_at.to_date, format: :long %>
      <% elsif @post.scheduled? %>
        · <span class="badge badge--accent">Scheduled ·
          <time datetime="<%= @post.published_at.iso8601 %>" data-controller="local-time"
                data-local-time-datetime-value="<%= @post.published_at.iso8601 %>"><%= @post.published_at.strftime("%b %-d at %H:%M") %></time></span>
      <% else %>
        · <span class="badge">Draft</span>
      <% end %>
    </p>
  </header>
</div>

<% if can_manage %>
  <%= render "admin/posts/broadcast_banner" %>
<% end %>

<article class="u-flow post-body">
  <%= @post.content %>
</article>

<%= render "admin/boosts/boosts", record: @record %>

<%= render "admin/comments/comments", record: @record %>
