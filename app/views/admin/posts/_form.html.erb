<%# locals: (post:, url:) %>
<%= render "admin/shared/error_summary", model: post %>

<%# Borderless composer: no visible labels (accessible names via aria-label). %>
<%# Submits from the canvas-head buttons (form: "composer"). %>
<%# Autosaved to localStorage: new posts share the posts/new draft slot; %>
<%# edits key to the record, guarded by the current version id. %>
<%= form_with model: post, url: url, id: "composer", class: "composer",
      data: { controller: "autosave",
              autosave_key_value: (post.record_id ? "Record/#{post.record_id}/edit" : "posts/new"),
              autosave_revision_value: post.record&.recordable_id } do |f| %>
  <%= f.text_field :title, class: "composer__title", placeholder: "Post title",
        "aria-label": "Title", required: true, autofocus: true %>

  <%= f.rich_textarea :content, placeholder: "Write away…", "aria-label": "Body" %>

  <%# Optional plain-text summary for the blog list + search results; falls back %>
  <%# to a truncation of the body when blank (Post#summary). %>
  <%= f.text_area :excerpt, class: "composer__excerpt", rows: 2,
        placeholder: "Optional summary for the blog list and search results…",
        "aria-label": "Excerpt" %>
<% end %>
