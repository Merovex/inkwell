<% content_for :title, "Analytics — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Analytics", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">Analytics</h1>
  <div class="perma-header__content">
    <p class="u-text-muted">Public-site traffic over the last 30 days.</p>
  </div>
</header>

<div class="analytics-totals">
  <div class="analytics-stat">
    <span class="analytics-stat__value"><%= number_with_delimiter @visitors %></span>
    <span class="analytics-stat__label u-microcaps">Unique visitors</span>
  </div>
  <div class="analytics-stat">
    <span class="analytics-stat__value"><%= number_with_delimiter @visits %></span>
    <span class="analytics-stat__label u-microcaps">Visits</span>
  </div>
  <div class="analytics-stat">
    <span class="analytics-stat__value"><%= number_with_delimiter @views %></span>
    <span class="analytics-stat__label u-microcaps">Page views</span>
  </div>
</div>

<section class="analytics-section">
  <h2 class="analytics-section__title">Geography</h2>
  <% if @geo_map.any? %>
    <div class="analytics-geo u-surface">
      <%# US state heat map while the audience is US-heavy; world otherwise. %>
      <% us_focused = @us_states.any? %>
      <div id="geo-map" class="analytics-geo__map" data-controller="geo-map"
           data-geo-map-map-value="<%= us_focused ? "us_aea_en" : "world" %>"
           data-geo-map-data-value="<%= (us_focused ? @us_states : @geo_map).to_json %>"></div>
      <div class="analytics-geo__lists">
        <h3 class="analytics-geo__heading u-microcaps u-text-muted">Countries</h3>
        <ul class="list list--compact">
          <% @countries.each do |country, count| %>
            <li class="list__item">
              <span class="list__body"><span class="list__title"><%= country %></span></span>
              <span class="badge"><%= count %></span>
            </li>
          <% end %>
        </ul>
        <% if @regions.any? %>
          <h3 class="analytics-geo__heading u-microcaps u-text-muted">Regions</h3>
          <ul class="list list--compact">
            <% @regions.each do |(region, country), count| %>
              <li class="list__item">
                <span class="list__body"><span class="list__title"><%= region %> <span class="u-text-muted">· <%= country %></span></span></span>
                <span class="badge"><%= count %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>
  <% else %>
    <p class="u-text-muted">No geography yet — visits are geocoded once the GeoLite2 database is in <code>storage/geoip/</code>.</p>
  <% end %>
</section>

<section class="analytics-section">
  <h2 class="analytics-section__title">Top landing pages</h2>
  <% if @landing_pages.any? %>
    <ul class="list list--compact">
      <% @landing_pages.each do |page, count| %>
        <li class="list__item">
          <span class="list__body"><span class="list__title"><%= url_path(page) %></span></span>
          <span class="badge"><%= count %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="u-text-muted">No visits yet.</p>
  <% end %>
</section>

<section class="analytics-section">
  <h2 class="analytics-section__title">Top referrers</h2>
  <% if @referrers.any? %>
    <ul class="list list--compact">
      <% @referrers.each do |domain, count| %>
        <li class="list__item">
          <span class="list__body"><span class="list__title"><%= domain %></span></span>
          <span class="badge"><%= count %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="u-text-muted">No referrers yet — mostly direct traffic.</p>
  <% end %>
</section>
