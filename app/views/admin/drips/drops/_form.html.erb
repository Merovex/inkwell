<%# locals: (drop:, url:) %>
<%= render "admin/shared/error_summary", model: drop %>

<%= form_with model: drop, url: url, class: "settings" do |f| %>
  <div class="field">
    <%= f.label :subject, "Subject", class: "field__label" %>
    <%= f.text_field :subject, class: "field__control", required: true, autofocus: true,
          placeholder: "Email subject line" %>
  </div>

  <div class="field">
    <%= f.label :delay_days, "Send day", class: "field__label" %>
    <%= f.number_field :delay_days, class: "field__control", min: 0, step: 1 %>
    <p class="u-text-muted">Days after the subscriber confirms. 0 = right away.</p>
  </div>

  <div class="field">
    <%= f.label :body, "Body", class: "field__label" %>
    <%= f.rich_textarea :body, placeholder: "Write the email…", "aria-label": "Body" %>
  </div>

  <%= f.submit "Save", class: "button button--primary" %>
<% end %>
