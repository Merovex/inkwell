<% content_for :title, "System settings — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["System settings", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">System settings</h1>
</header>

<div class="settings u-center u-center-narrow">
  <%# Press / site identity — the public Merovex Press face. One form; logo and
      the text fields save together. Future sections (members, email…) slot in
      below as their own <section>s. %>
  <section class="settings__section" aria-label="Press identity">
    <%= render "admin/shared/error_summary", model: @setting %>

    <%= form_with model: @setting, url: admin_settings_path, method: :patch, multipart: true do |f| %>
      <div class="field">
        <%= f.label :logo, "Logo", class: "field__label" %>
        <% if @setting.logo.attached? %>
          <%= image_tag @setting.logo, class: "settings__logo-preview", alt: "Current logo" %>
        <% end %>
        <%= f.file_field :logo, accept: Setting::LOGO_CONTENT_TYPES.join(","), class: "field__control" %>
        <p class="field__hint u-text-muted">Shown in the public site header; the Merovex wordmark is used when blank. JPG, PNG, AVIF, WebP, or SVG, up to <%= Setting::LOGO_MAX_SIZE / 1.megabyte %> MB.</p>
      </div>

      <div class="field">
        <%= f.label :site_name, "Site name", class: "field__label" %>
        <%= f.text_field :site_name, class: "field__control", placeholder: "Merovex Press", required: true %>
        <p class="field__hint u-text-muted">The name in the browser tab, public header, and footer.</p>
      </div>

      <div class="field">
        <%= f.label :tagline, "Tagline", class: "field__label" %>
        <%= f.text_field :tagline, class: "field__control", placeholder: "A one-line description" %>
        <p class="field__hint u-text-muted">Sits beside the site name in the page title.</p>
      </div>

      <div class="field">
        <%= f.label :description, "About", class: "field__label" %>
        <%= f.rich_textarea :description, placeholder: "About the press…", "aria-label": "About" %>
        <p class="field__hint u-text-muted">Feeds the public page description; a plain-text summary is used where formatting can't render.</p>
      </div>

      <div class="field">
        <%= f.label :contact_email, "Contact email", class: "field__label" %>
        <%= f.email_field :contact_email, class: "field__control", placeholder: "hello@merovex.press" %>
        <p class="field__hint u-text-muted">Where the public footer's contact link points.</p>
      </div>

      <%= f.submit "Save", class: "button button--primary" %>
    <% end %>
  </section>
</div>
