<% content_for :title, "Broadcasts — Inkwell" %>

<%= render "admin/shared/canvas_head", crumbs: [["Broadcasts", nil]] %>

<header class="perma-header">
  <h1 class="perma-header__title">Broadcasts</h1>
  <div class="perma-header__content">
    <p class="u-text-muted">Posts emailed to subscribers, and how each one landed.</p>
  </div>
</header>

<% pct = ->(rate) { rate ? number_to_percentage(rate * 100, precision: 0) : "—" } %>

<% if @broadcasts.any? %>
  <div class="table-scroll">
    <table class="table table--nowrap">
      <thead>
        <tr>
          <th scope="col">Post</th>
          <th scope="col">Sent</th>
          <th scope="col" data-align="end">Recipients</th>
          <th scope="col" data-align="end">Delivered</th>
          <th scope="col" data-align="end">Opens</th>
          <th scope="col" data-align="end">Clicks</th>
          <th scope="col" data-align="end">Bounces</th>
          <th scope="col" data-align="end">Unsubs</th>
        </tr>
      </thead>
      <tbody>
        <% @broadcasts.each do |broadcast| %>
          <tr>
            <td>
              <%= link_to broadcast.post&.title.presence || "Untitled", admin_post_path(broadcast.record), class: "u-text-strong" %>
            </td>
            <td>
              <% case broadcast.state %>
              <% when :sent %>
                <%= l broadcast.sent_at.to_date, format: :long %>
              <% when :scheduled %>
                <span class="badge badge--accent">Scheduled ·
                  <time datetime="<%= broadcast.scheduled_at.iso8601 %>" data-controller="local-time"
                        data-local-time-datetime-value="<%= broadcast.scheduled_at.iso8601 %>"><%= broadcast.scheduled_at.strftime("%b %-d at %H:%M") %></time></span>
              <% else %>
                <span class="badge">Sending…</span>
              <% end %>
            </td>
            <td data-align="end"><%= broadcast.recipients_count %></td>
            <td data-align="end"><%= broadcast.delivered_count %> <span class="u-text-muted u-text-small"><%= pct.(broadcast.delivery_rate) %></span></td>
            <td data-align="end"><%= broadcast.opened_count %> <span class="u-text-muted u-text-small"><%= pct.(broadcast.open_rate) %></span></td>
            <td data-align="end"><%= broadcast.clicked_count %> <span class="u-text-muted u-text-small"><%= pct.(broadcast.click_rate) %></span></td>
            <td data-align="end"><%= broadcast.bounced_count %></td>
            <td data-align="end"><%= broadcast.unsubscribed_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty">
    <span class="empty__icon"><%= inline_svg_tag "lucide/inbox.svg", class: "lucide", size: "40px" %></span>
    <p class="empty__title">No broadcasts yet</p>
    <p class="empty__text">Email a published post to your subscribers from its page and it'll show up here.</p>
  </div>
<% end %>
