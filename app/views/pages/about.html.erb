<% content_for :title, "About — #{site_settings.site_name}" %>

<article class="press-article">
  <header class="press-article__head">
    <h1 class="press-article__title">About <%= site_settings.site_name %></h1>
    <% if site_settings.tagline.present? %>
      <p class="press-article__byline"><%= site_settings.tagline %></p>
    <% end %>
  </header>

  <div class="press-article__body prose">
    <% if site_settings.description.present? %>
      <%= site_settings.description %>
    <% else %>
      <p>More about <%= site_settings.site_name %> is coming soon.</p>
    <% end %>
  </div>
</article>
