<% content_for :title, "About — #{site_settings.site_name}" %>

<article class="press-shell">
  <header class="press-header u-flow u-flow-half">
    <h1 class="press-display-lg">About <%= site_settings.site_name %></h1>
    <% if site_settings.tagline.present? %>
      <p class="press-muted"><%= site_settings.tagline %></p>
    <% end %>
  </header>

  <div class="press-body prose">
    <% if site_settings.description.present? %>
      <%= site_settings.description %>
    <% else %>
      <p>More about <%= site_settings.site_name %> is coming soon.</p>
    <% end %>
  </div>
</article>
