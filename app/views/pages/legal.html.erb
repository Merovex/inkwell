<% content_for :title, "#{@title} — #{site_settings.site_name}" %>

<article class="press-shell">
  <header class="press-header u-flow u-flow-half">
    <h1 class="press-display-lg"><%= @title %></h1>
  </header>

  <div class="press-body prose">
    <% if @body.present? %>
      <%= @body %>
    <% else %>
      <p>This page isn't available yet.</p>
    <% end %>
  </div>
</article>
