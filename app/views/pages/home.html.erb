<%# Static Merovex Press home page — mirrors the merovex.press split hero + genre
    cards. All links are placeholders (#) for now. %>

<section class="press-hero">
  <div class="press-hero__text">
    <h1 class="press-display-xl">Worlds break. People don't.</h1>
    <p class="press-hero__lede press-muted">
      Science fiction, fantasy, and alternate history from pen names
      Ben Wilson and Troy Buzby.
    </p>
    <div class="u-cluster u-gap u-cluster-center">
      <%= link_to "Join the Newsletter", newsletter_path(source: "hero"), class: "press-btn press-btn--primary" %>
      <%= link_to "Browse books", books_path, class: "press-btn press-btn--outline" %>
    </div>
  </div>

  <div class="press-hero__photo">
    <div class="press-hero__ring">
      <%# The ring displays at ≤340px wide (4:5), so ship 500w/1000w for 1×/2×
          instead of the 2000×2500 original — much smaller for the LCP element.
          Preload matches the srcset/sizes so the browser fetches the right one
          first, before lazy/below-the-fold work. %>
      <% hero_srcset = "#{image_path('authors/ben-headshot-2026_1-500.avif')} 500w, #{image_path('authors/ben-headshot-2026_1-1000.avif')} 1000w" %>
      <% hero_sizes = "(min-width: 900px) 340px, min(280px, 70vw)" %>
      <% content_for :head do %>
        <link rel="preload" as="image" imagesrcset="<%= hero_srcset %>" imagesizes="<%= hero_sizes %>" fetchpriority="high">
      <% end %>
      <%= image_tag "authors/ben-headshot-2026_1-1000.avif",
            alt: "Merovex Press", width: 400, height: 500, loading: "eager", fetchpriority: "high",
            srcset: hero_srcset, sizes: hero_sizes %>
    </div>
  </div>
</section>

<% if @scroller_books.any? %>
  <% cache [ cover_fragment_version, @scroller_books ] do %>
    <%= render "pages/overflow_scroller", books: @scroller_books %>
  <% end %>
<% end %>

<section class="press-genres">
  <article class="press-card press-genre-card">
    <p class="press-kicker">Ben Wilson</p>
    <h2 class="press-display-md">Science fiction &amp; fantasy</h2>
    <p class="press-muted">
      The heroes nobody remembers, in worlds that don't deserve them.
      Military science fiction and dark fantasy. Postal Marines. Company of Heretics.
    </p>
  </article>

  <article class="press-card press-genre-card">
    <p class="press-kicker">Troy Buzby</p>
    <h2 class="press-display-md">Alternate history</h2>
    <p class="press-muted">
      Nobody knows when they're living through history.
      Character-driven alternate history. The Strand series.
    </p>
  </article>
</section>
