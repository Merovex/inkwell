<%# Static Merovex Press home page — mirrors the merovex.press split hero + genre
    cards. All links are placeholders (#) for now. %>

<section class="press-hero">
  <div class="press-hero__text">
    <h1 class="press-hero__headline">Worlds break. People don't.</h1>
    <p class="press-hero__lede">
      Science fiction, fantasy, and alternate history from pen names
      Ben Wilson and Troy Buzby.
    </p>
    <div class="press-hero__actions">
      <%= link_to "Join the Newsletter", newsletter_path(source: "hero"), class: "press-btn press-btn--primary" %>
      <%= link_to "Browse books", books_path, class: "press-btn press-btn--outline" %>
    </div>
  </div>

  <div class="press-hero__photo">
    <div class="press-hero__ring">
      <%# The hero is the LCP element — preload it and mark it high priority so the
          browser fetches it before lazy/below-the-fold work. %>
      <% content_for :head do %>
        <link rel="preload" as="image" href="<%= image_path("authors/ben-headshot-2026_1.avif") %>" fetchpriority="high">
      <% end %>
      <%= image_tag "authors/ben-headshot-2026_1.avif",
            alt: "Merovex Press", width: 400, height: 400, loading: "eager", fetchpriority: "high" %>
    </div>
  </div>
</section>

<section class="press-genres">
  <article class="press-genre-card">
    <p class="press-genre-card__label">Ben Wilson</p>
    <h3 class="press-genre-card__title">Science fiction &amp; fantasy</h3>
    <p class="press-genre-card__blurb">
      The heroes nobody remembers, in worlds that don't deserve them.
      Military science fiction and dark fantasy. Postal Marines. Company of Heretics.
    </p>
    <a href="#" class="press-genre-card__more">Explore books &rarr;</a>
  </article>

  <article class="press-genre-card">
    <p class="press-genre-card__label">Troy Buzby</p>
    <h3 class="press-genre-card__title">Alternate history</h3>
    <p class="press-genre-card__blurb">
      Nobody knows when they're living through history.
      Character-driven alternate history. The Strand series.
    </p>
    <a href="#" class="press-genre-card__more">Explore books &rarr;</a>
  </article>
</section>
