<%# locals: (record:) %>
<%# The boost strip under a record's content: one badge per boost, then the %>
<%# "+ Boost" chip. It discloses a bordered field holding the text input and %>
<%# three triggers: smiley (emoji palette popover, floated above), circle- %>
<%# check (submit), circle-x (reset + close). Every action redirects back to %>
<%# the page and Turbo extracts this frame from it, so the strip swaps in %>
<%# place with the composer back at rest. %>
<%= turbo_frame_tag dom_id(record, :boosts), class: "boosts" do %>
  <%= render partial: "boosts/boost", collection: record.boosts.includes(creator: { avatar_attachment: :blob }) %>

  <details class="boosts__composer" data-controller="disclosure">
    <summary class="badge boosts__prompt">+ Boost</summary>

    <%= form_with url: record_boosts_path(record), scope: :boost, class: "boosts__field" do %>
      <%= text_field_tag "boost[content]", nil, maxlength: Boost::MAX_LENGTH, class: "boosts__input",
            placeholder: "🙌 or a few words", autocomplete: "off", aria: { label: "Boost" } %>
      <button type="button" class="boosts__icon" popovertarget="boost-menu-<%= record.id %>" aria-label="Pick an emoji">
        <%= inline_svg_tag "lucide/smile-plus.svg", class: "lucide", size: "16px" %>
      </button>
      <button type="submit" class="boosts__icon" title="Add boost" aria-label="Add boost">
        <%= inline_svg_tag "lucide/circle-check.svg", class: "lucide", size: "16px" %>
      </button>
      <button type="reset" class="boosts__icon" data-action="disclosure#close" title="Cancel" aria-label="Cancel">
        <%= inline_svg_tag "lucide/circle-x.svg", class: "lucide", size: "16px" %>
      </button>
    <% end %>
  </details>

  <div class="menu boosts__palette" popover id="boost-menu-<%= record.id %>"
       data-controller="anchored-popover" data-anchored-popover-placement-value="above">
    <% Boost::COMMON_EMOJIS.each do |emoji| %>
      <%= button_to emoji, record_boosts_path(record), params: { boost: { content: emoji } },
            class: "boosts__emoji", form: { class: "boost__form" }, aria: { label: "Boost with #{emoji}" } %>
    <% end %>
  </div>
<% end %>
