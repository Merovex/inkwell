<% content_for :title, "Sign in" %>

<div class="card auth__card">
  <% if params[:sent] %>
    <header class="card__header"><span class="card__title">Check your email</span></header>
    <div class="card__body u-stack">
      <p class="u-text-muted">If that address has an account, we've sent a sign-in link. Open it on this device, or enter the code from the email below.</p>

      <%= form_with url: verify_session_path, method: :get do |f| %>
        <div class="field">
          <span class="field__label" id="code-label">Sign-in code</span>
          <div class="code-input" role="group" aria-labelledby="code-label" data-controller="code-field">
            <% 8.times do |i| %>
              <% if i == 4 %><span class="code-input__sep" aria-hidden="true">&ndash;</span><% end %>
              <input class="code-input__box" type="text" inputmode="text" maxlength="1"
                     autocapitalize="characters" autocomplete="off" spellcheck="false"
                     aria-label="Character <%= i + 1 %>"<%= " autofocus" if i.zero? %>
                     data-code-field-target="box"
                     data-action="input->code-field#onInput keydown->code-field#onKeydown paste->code-field#onPaste">
            <% end %>
            <%= f.hidden_field :code, data: { "code-field-target": "hidden" } %>
          </div>
          <span class="field__hint">Enter the eight letters from your email — pasting the code works too.</span>
        </div>
        <%= f.submit "Sign in", class: "button button--primary u-full-width", style: "margin-block-start: var(--u-pad);" %>
      <% end %>

      <%= link_to "Use a different email", new_session_path, class: "u-text-muted" %>
    </div>
  <% else %>
    <header class="card__header"><span class="card__title">Sign in to Alcovo</span></header>
    <div class="card__body u-stack">
      <p class="u-text-muted">Enter your email and we'll send you a magic link — no password needed.</p>

      <%= form_with url: session_path, method: :post, class: "field" do |f| %>
        <%= f.label :email_address, "Email", class: "field__label" %>
        <%= f.email_field :email_address, class: "field__control", placeholder: "you@example.com", required: true, autofocus: true, autocomplete: "email" %>
        <%= f.submit "Send magic link", class: "button button--primary", style: "margin-block-start: var(--u-pad);" %>
      <% end %>
    </div>
  <% end %>
</div>
