<% content_for :title, "#{@message.title} — Alcovo" %>
<% can_manage = allowed_to?(:manage, @record) %>

<%# The title is editable in place (creator/admin only): click it. Saving %>
<%# submits the enclosed form (PATCH messages#update) — on a posted message %>
<%# that's a tracked rename. %>
<div data-controller="editable">
  <%= render "shared/canvas_head", crumbs: [["Forum", messages_path], [@message.title, nil]],
        edit_href: (edit_message_path(@record) if can_manage) do %>
    <% if can_manage %>
      <% if @message.published? %>
        <% if @message.pinned_at %>
          <%= button_to "Unpin", message_pin_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
        <% else %>
          <%= button_to "Pin", message_pin_path(@record), class: "menu__item", role: "menuitem" %>
        <% end %>
        <%= button_to "Revert to draft", message_publish_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
      <% else %>
        <%= button_to "Post", message_publish_path(@record), class: "menu__item", role: "menuitem" %>
      <% end %>
      <hr class="menu__separator">
    <% end %>
    <%= link_to "View History", message_events_path(@record), class: "menu__item", role: "menuitem" %>
    <% if can_manage %>
      <hr class="menu__separator">
      <%= button_to "Move to trash", message_path(@record), method: :delete, class: "menu__item", role: "menuitem" %>
    <% end %>
  <% end %>

  <header class="perma-header">
    <% if can_manage %>
      <h1 class="perma-header__title editable__display" data-editable-target="display"
          data-action="click->editable#edit" title="Click to rename" tabindex="0"><%= @message.title %></h1>
      <%= form_with model: @message, url: message_path(@record) do |f| %>
        <%= f.text_field :title, hidden: true, class: "perma-header__title editable__input",
              aria: { label: "Title" },
              data: { editable_target: "input",
                      action: "blur->editable#save keydown.enter->editable#save keydown.esc->editable#cancel" } %>
      <% end %>
    <% else %>
      <h1 class="perma-header__title"><%= @message.title %></h1>
    <% end %>
    <%# The byline leads with the category, Basecamp style: "📢 Announcement %>
    <%# by Ben Wilson · Jul 3". %>
    <p class="perma-header__content u-text-muted">
      <% if @message.category %><%= @message.category.label %> by<% end %>
      <span class="u-text-strong"><%= @record.creator.display_name %></span>
      <% if @message.published? %>
        · <%= l @message.published_at.to_date, format: :long %>
      <% elsif @message.scheduled? %>
        · <span class="badge badge--accent">Scheduled · <%= @message.published_at.strftime("%b %-d at %H:%M") %></span>
      <% else %>
        · <span class="badge">Draft</span>
      <% end %>
    </p>
  </header>
</div>

<article class="u-flow">
  <%= @message.content %>
</article>

<%= render "boosts/boosts", record: @record %>

<%= render "comments/comments", record: @record %>
