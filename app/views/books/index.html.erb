<% content_for :title, "Books — Merovex Press" %>

<div class="press-shell press-shell--wide">
  <header class="press-measure u-flow u-text-center">
    <h1 class="press-display-xl">The Library</h1>
    <p class="press-lede">
      Alternate history, science fiction, and fantasy — organized by series.
    </p>
  </header>

  <% @series.each do |series, books| %>
    <% cache [ series, books ] do %>
      <section class="press-series u-flow">
        <h2 class="press-display-md u-text-center"><%= series.title %></h2>
        <% blurb = series.content.to_plain_text.to_s %>
        <% if blurb.present? %>
          <p class="press-muted press-measure u-text-center"><%= truncate(blurb, length: 260) %></p>
        <% end %>
        <div class="press-book-grid">
          <% books.each do |book| %>
            <%= render "books/card", book: book, series: series %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>

  <% if @standalone.any? %>
    <% cache @standalone do %>
      <section class="press-series u-flow">
        <h2 class="press-display-md u-text-center">Standalone</h2>
        <div class="press-book-grid">
          <% @standalone.each do |book| %>
            <%= render "books/card", book: book %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>

  <% if @series.empty? && @standalone.empty? %>
    <p class="press-muted u-text-center">No books published yet — check back soon.</p>
  <% end %>
</div>
