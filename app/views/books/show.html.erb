<% content_for :title, "#{@book.title} — #{site_settings.site_name}" %>
<% content_for :meta_description, @book.content.to_plain_text.to_s.truncate(200) %>
<% content_for :og_image, url_for(@book.cover) if @book.cover? %>
<% content_for :json_ld do %>
  <%= json_ld_tag({
    "@context": "https://schema.org",
    "@type": "Book",
    "name": @book.title,
    "author": { "@type": "Person", "name": @book.byline },
    "datePublished": @book.publication_date&.iso8601,
    "image": (url_for(@book.cover) if @book.cover?),
    "publisher": { "@type": "Organization", "name": site_settings.site_name }
  }) %>
<% end %>

<article class="press-shell">
  <a href="<%= books_path %>" class="press-back">
    <%= inline_svg_tag "lucide/chevron-right.svg", class: "lucide press-back__icon", size: "16px" %>
    All books
  </a>

  <div class="press-book__top">
    <% if @book.cover? %>
      <%= image_tag @book.cover, class: "press-book__cover", alt: "#{@book.title} cover" %>
    <% end %>
    <div class="press-book__meta u-flow u-flow-half">
      <% series = @book.series %>
      <% if series.any? %>
        <p class="press-kicker"><%= series.map(&:title).to_sentence %></p>
      <% end %>
      <h1 class="press-display-lg"><%= @book.title %></h1>
      <p class="press-muted">by <%= byline_link(@book) %></p>
      <% if @book.publication_date %>
        <p class="press-faint"><%= @book.publication_date.strftime("%B %Y") %></p>
      <% end %>
      <% if @record.distributors.any? %>
        <div class="u-cluster u-gap">
          <% @record.distributors.order(:platform).each do |distributor| %>
            <a href="<%= buy_path(distributor) %>" class="press-btn press-btn--primary" target="_blank" rel="noopener">
              <%= distributor.display_name %>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="press-body prose"><%= @book.content %></div>

  <% @series.each do |series, books| %>
    <% cache [ series, books, @record ] do %>
      <section class="press-series u-flow">
        <h2 class="press-display-md u-text-center">More in <%= series.title %></h2>
        <% blurb = series.content.to_plain_text.to_s %>
        <% if blurb.present? %>
          <p class="press-muted press-measure u-text-center"><%= truncate(blurb, length: 260) %></p>
        <% end %>
        <div class="press-book-grid">
          <% books.each do |book| %>
            <%= render "books/card", book: book, series: series %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</article>
